# API Configuration
PROJECT_NAME="Professional LLM Portfolio API"
API_V1_STR="/api/v1"
DEBUG=true

# LLM Configuration
# Choose provider: openai, ollama, or mock
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# For Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Logging
LOG_LEVEL=INFO
